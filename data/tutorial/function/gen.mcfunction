summon minecraft:text_display 0.5 16.3 -43.5 {"Tags":["tutorial"],"view_range":0.05,"text":{translate:"bf.tutorial.2.text",fallback:"橋に乗っている人が減る度に、\n橋は耐久値が1減少します。\n耐久値が0になってしまった場合、\n橋は§l破壊§rされます。\n（チュートリアルの橋は耐久値が1）"},"Rotation":[180,0],background:-2013265920}
